# ─── Supabase ──────────────────────────────────────────────────────────────────
# Production: use your prod Supabase project
# Preview/Dev: use a separate dev Supabase project
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ─── Session ───────────────────────────────────────────────────────────────────
# Random 32-byte hex string. Generate with: openssl rand -hex 32
AUTH_SECRET=<random-hex-string>

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at console.cloud.google.com
# Add both prod and preview redirect URIs in the OAuth app
GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>

# ─── Plaid ─────────────────────────────────────────────────────────────────────
# Production: PLAID_ENV=production
# Preview/Dev: PLAID_ENV=sandbox
PLAID_CLIENT_ID=<plaid-client-id>
PLAID_SECRET=<plaid-secret>
PLAID_ENV=sandbox

# ─── Encryption ────────────────────────────────────────────────────────────────
# 32-byte key for AES-256-GCM. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=<32-byte-hex-key>

# ─── PostHog (optional in dev) ─────────────────────────────────────────────────
VITE_POSTHOG_KEY=<posthog-project-api-key>
VITE_POSTHOG_HOST=https://app.posthog.com
